# Copy this file to terraform.tfvars and fill in your values.

derper_hostname = "derp.example.click"   # full hostname for the DERP server
route53_zone    = "example.click"         # Route 53 hosted zone (must already exist)

# Optional overrides (defaults in variables.tf):
# region              = "ap-east-2"        # AWS Taipei
# aws_profile         = "willy"
# instance_type       = "t3.micro"          # ~$10/mo. t4g.micro (ARM) is ~$8/mo.
# ssh_public_key_path = "~/.ssh/id_ed25519.pub"
